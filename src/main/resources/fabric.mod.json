{
	"schemaVersion": 1,
	"id": "shiftism",
	"version": "${version}",
	"name": "shiftism",
	"description": "All about the isms of shifting.",
	"authors": [
		"novaliyn"
	],
	"contact": {
		"homepage": "https://nova.mysticpeak.com",
		"sources": "https://github.com/novaliyn/shiftism"
	},
	"license": "CC0-1.0",
	"icon": "assets/shiftism/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.novaliyn.shiftism.Shiftism"
		],
		"client": [
			"com.novaliyn.shiftism.ShiftismClient"
		],
		"fabric-datagen": [
			"com.novaliyn.shiftism.ShiftismDataGenerator"
		]
	},
	"mixins": [
		"shiftism.mixins.json",
		{
			"config": "shiftism.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}